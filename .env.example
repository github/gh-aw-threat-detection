# Environment variables for gh-aw-threat-detection
#
# REQUIRED FOR AI ENGINE EXECUTION (pick one based on --engine flag):
#
# Copilot engine (default):
# Requires the `copilot` CLI to be installed and authenticated.
# No additional env vars needed if `copilot` CLI is already logged in.

# Claude engine:
# Requires the `claude` CLI to be installed.
# ANTHROPIC_API_KEY=             # Required for Claude engine authentication

# Codex engine:
# Requires the `codex` CLI to be installed.
# OPENAI_API_KEY=                # Required for Codex engine authentication

# OPTIONAL - used by the artifacts loader:
# WORKFLOW_NAME=                  # Name of the workflow being analyzed (default: "Unnamed Workflow")
# WORKFLOW_DESCRIPTION=           # Description of the workflow (default: "No description provided")
# CUSTOM_PROMPT=                  # Additional detection instructions appended to the default prompt

# CI/CD (configured as GitHub repo/org secrets, not needed locally):
# GITHUB_TOKEN=                   # Automatic in GitHub Actions; used for GHCR push
